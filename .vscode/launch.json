{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\test.js"
        },
        {
            "type": "node-terminal",
            "name": "Run Script: start (test)",
            "request": "launch",
            "command": "npm run start",
            "cwd": "${workspaceFolder}\\test"
        },
        {
            "type": "node-terminal",
            "name": "Run Script: start (theme-toggle)",
            "request": "launch",
            "command": "npm run start",
            "cwd": "${workspaceFolder}\\Pesto class code\\react code pesto\\pesto-react-13\\theme-toggle"
        }
    ]
}